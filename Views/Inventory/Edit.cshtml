@model Inventory_System.Models.InventoryItem

@{
    ViewData["Title"] = "Edit Item";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1 class="mb-4"><i class="bi bi-pencil"></i> Edit Inventory Item</h1>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedDate" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Item Name *</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Category" class="form-label">Category *</label>
                                <input asp-for="Category" class="form-control" required />
                                <span asp-validation-for="Category" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Quantity" class="form-label">Quantity *</label>
                                <input asp-for="Quantity" type="number" class="form-control" min="0" required />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="UnitPrice" class="form-label">Unit Price ($) *</label>
                                <input asp-for="UnitPrice" type="number" step="0.01" class="form-control" min="0" required />
                                <span asp-validation-for="UnitPrice" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="LowStockThreshold" class="form-label">Low Stock Threshold</label>
                                <input asp-for="LowStockThreshold" type="number" class="form-control" min="0" />
                                <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 p-3 bg-light rounded">
                        <p class="mb-2"><strong>Calculated Total Value:</strong> $@(Model.Quantity * Model.UnitPrice).ToString("F2")</p>
                        <p class="mb-0 text-muted"><small>Created: @Model.CreatedDate.ToString("g")</small></p>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Update Item</button>
                        <a href="~/Inventory/Index" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
