@model Inventory_System.Models.InventoryItem

@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-box"></i> @Model.Name</h1>
            <div>
                <a href="~/Inventory/Edit/@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
                <a href="~/Inventory/Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h5 class="card-title">Item Information</h5>
                        <table class="table table-borderless">
                            <tr>
                                <th>Category:</th>
                                <td><span class="badge bg-primary">@Model.Category</span></td>
                            </tr>
                            <tr>
                                <th>Description:</th>
                                <td>@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</td>
                            </tr>
                            <tr>
                                <th>Created:</th>
                                <td>@Model.CreatedDate.ToString("g")</td>
                            </tr>
                            <tr>
                                <th>Last Updated:</th>
                                <td>@Model.UpdatedDate.ToString("g")</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h5 class="card-title">Stock & Pricing</h5>
                        <table class="table table-borderless">
                            <tr>
                                <th>Quantity:</th>
                                <td><strong>@Model.Quantity</strong></td>
                            </tr>
                            <tr>
                                <th>Unit Price:</th>
                                <td><strong>$@Model.UnitPrice.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <th>Total Value:</th>
                                <td><strong class="text-success">$@Model.TotalValue.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <th>Low Stock Threshold:</th>
                                <td>@Model.LowStockThreshold</td>
                            </tr>
                            <tr>
                                <th>Status:</th>
                                <td>
                                    @if (Model.IsLowStock)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Low Stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> In Stock</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <hr />

                <div class="d-flex gap-2">
                    <a href="~/Inventory/Edit/@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit Item</a>
                    <a href="~/Inventory/Delete/@Model.Id" class="btn btn-danger"><i class="bi bi-trash"></i> Delete Item</a>
                    <a href="~/Inventory/Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Inventory</a>
                </div>
            </div>
        </div>
    </div>
</div>
