@{
    ViewData["Title"] = "Dashboard";
    var stats = ViewBag.Stats;
}

<div class="row">
    <div class="col-md-3">
        <div class="stat-box stat-box-primary">
            <i class="bi bi-box" style="font-size: 2rem;"></i>
            <h3>@stats.TotalItems</h3>
            <p>Total Items</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-box stat-box-info">
            <i class="bi bi-stack" style="font-size: 2rem;"></i>
            <h3>@stats.TotalQuantity</h3>
            <p>Total Quantity</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-box stat-box-success">
            <i class="bi bi-cash-coin" style="font-size: 2rem;"></i>
            <h3>$@stats.TotalValue.ToString("F2")</h3>
            <p>Total Value</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-box stat-box-warning">
            <i class="bi bi-exclamation-triangle" style="font-size: 2rem;"></i>
            <h3>@stats.LowStockCount</h3>
            <p>Low Stock Items</p>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body text-center py-5">
                <h2 class="mb-3">Welcome to Inventory Management System</h2>
                <p class="text-muted mb-4">Manage your inventory efficiently with pricing, stock tracking, and reporting.</p>
                <a href="~/Inventory/Index" class="btn btn-primary btn-lg me-2"><i class="bi bi-list"></i> View Inventory</a>
                <a href="~/Inventory/Create" class="btn btn-success btn-lg"><i class="bi bi-plus-circle"></i> Add New Item</a>
            </div>
        </div>
    </div>
</div>
